n        <div className=\"flex items-center gap-3\">\n          <button\n            type=\"button\"\n            onClick={() => setNotes(exampleNotes)}\n            disabled={isPending}\n            className=\"text-xs text-[var(--color-ink-muted)] underline underline-offset-2 hover:text-[var(--color-ink)]\"\n          >\n            Try example notes for {firstName(leadName)}\n          </button>\n          <span className=\"text-xs text-[var(--color-ink-muted)]\">{charCount} chars (need 20+)</span>\n        </div>\n        <button\n          type=\"submit\"\n          disabled={!canSubmit}\n          className=\"rounded-md bg-[var(--color-brand)] px-6 py-2.5 text-sm font-medium text-white hover:bg-[var(--color-brand-dark)] disabled:opacity-40 disabled:cursor-not-allowed\"\n        >\n          {isPending ? \"Working\u2026\" : \"Draft proposal\"}\n        </button>\n      </div>\n\n      {isPending && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm\">\n          <div className=\"w-full max-w-lg rounded-2xl border border-[var(--color-line)] bg-[var(--color-card)] p-10 shadow-2xl\">\n            <div className=\"text-center\">\n              <div className=\"mb-2 text-xs font-medium uppercase tracking-widest text-[var(--color-brand-dark)]\">\n                Drafting proposal\n              </div>\n              <div className=\"text-2xl font-semibold tracking-tight text-[var(--color-ink)]\">\n                {PROGRESS_MESSAGES[messageIdx]}\n              </div>\n            </div>\n            <div className=\"mt-8\">\n              <div className=\"mb-2 flex items-center justify-between text-sm\">\n                <span className=\"text-[var(--color-ink-muted)]\">Working through your notes</span>\n                <span className=\"tabular-nums font-semibold text-[var(--color-ink)]\">{Math.round(progress)}%</span>\n              </div>\n              <div className=\"h-3 w-full overflow-hidden rounded-full bg-[var(--color-canvas)]\">\n                <div\n                  className=\"h-full rounded-full bg-[var(--color-brand)]\"\n                  style={{ width: `${progress}%`, transition: \"width 200ms ease-out\" }}\n                />\n              </div>\n              <p className=\"mt-6 text-center text-xs text-[var(--color-ink-muted)]\">\n                Hang tight, this takes about 30 seconds. Do not close the tab.\n              </p>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {error && (\n        <div className=\"rounded-lg border border-[var(--color-danger)]/30 bg-[var(--color-danger-soft)] p-3 text-sm text-[var(--color-danger)]\">\n          {error}\n        </div>\n      )}\n    </form>\n  );\n}\n\nfunction firstName(full: string): string {\n  return (full ?? \"\").trim().split(/\\s+/)[0] || \"this lead\";\n}\n\n/**\n * Build a plausible \"site walk dictation\" tailored to the lead's intake notes.\n *\n * Strategy: frame as Marcus's post-walk dictation, anchor on the lead's first name, then weave\n * intake notes back into Marcus's voice. If intake is empty, falls back to a generic Phoenix\n * backyard scope so the user can still test the flow.\n */\nfunction buildExampleNotes(name: string, intake: string, source: string | null)", "source_file": "/home/marcio/Claude/Profissional/LicenseScale-Test/build/app/leads/[id]/DraftForm.tsx", "source_location": "L101"}, {"caller_nid": "draftform_draftform", "callee": "{charCount}", "source_file": "/home/marcio/Claude/Profissional/LicenseScale-Test/build/app/leads/[id]/DraftForm.tsx", "source_location": "L111"}, {"caller_nid": "draftform_draftform", "callee": "round", "source_file": "/home/marcio/Claude/Profissional/LicenseScale-Test/build/app/leads/[id]/DraftForm.tsx", "source_location": "L136"}, {"caller_nid": "draftform_draftform", "callee": "split", "source_file": "/home/marcio/Claude/Profissional/LicenseScale-Test/build/app/leads/[id]/DraftForm.tsx", "source_location": "L162"},